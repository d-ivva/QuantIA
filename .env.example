# =============================================================
# Docker Compose — Variáveis de Ambiente
# =============================================================
# Copie este arquivo para .env e preencha com suas credenciais:
#   cp .env.example .env
#
# O arquivo .env NÃO é commitado no repositório (.gitignore).
# =============================================================

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=sua_senha_postgres_aqui
POSTGRES_DB=quantia

# --- pgAdmin ---
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=sua_senha_pgadmin_aqui

# --- Keycloak ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=sua_senha_keycloak_aqui
